---
import Layout from "../layouts/Layout.astro";
---

<Layout title="Submission Guidelines | ISEE 2026" bodyClass="inner-page">

      <main class="main">

        <div class="page-title light-background">
            <div class="container">
                <h1>Paper Submission Guidelines</h1>
                <nav class="breadcrumbs">
                    <ol>
                        <li><a href="index.html">Home</a></li>
                        <li class="current">Submission</li>
                    </ol>
                </nav>
            </div>
        </div>

        <section id="features-cards" class="features-cards section hero-date">
            <div class="container section-title pb-0" data-aos="fade-up">
                <h2>Important Dates</h2>
            </div>

            <section id="hero" class="hero-date pt-1">
            <div class="container" data-aos="fade-up" data-aos-delay="100">
                <div class="row stats-row gy-4 mt-5" data-aos="fade-up" data-aos-delay="500">

                <!-- Abstract Submission -->
                <div class="col-lg-4 col-md-6">
                    <div class="stat-item">
                    <div class="stat-icon">
                        <i class="bi bi-file-earmark-text"></i>
                    </div>
                    <div class="stat-content">
                        <h4>15 April 2026</h4>
                        <p class="mb-0">Abstract Submission</p>
                    </div>
                    </div>
                </div>

                <!-- Acceptance Notification -->
                <div class="col-lg-4 col-md-6">
                    <div class="stat-item">
                    <div class="stat-icon">
                        <i class="bi bi-check-circle"></i>
                    </div>
                    <div class="stat-content">
                        <h4>30 April 2026</h4>
                        <p class="mb-0">Acceptance Notification</p>
                    </div>
                    </div>
                </div>

                <!-- Full Paper Submission -->
                <div class="col-lg-4 col-md-6">
                    <div class="stat-item">
                    <div class="stat-icon">
                        <i class="bi bi-journal-album"></i>
                    </div>
                    <div class="stat-content">
                        <h4>11 June 2026</h4>
                        <p class="mb-0">Full Paper Submission</p>
                    </div>
                    </div>
                </div>

                <!-- Acceptance Notification of Full Paper -->
                <div class="col-lg-4 col-md-6">
                    <div class="stat-item">
                    <div class="stat-icon">
                        <i class="bi bi-clipboard2-check-fill"></i>
                    </div>
                    <div class="stat-content">
                        <h4>30 June 2026</h4>
                        <p class="mb-0">Acceptance Notification of Full Paper</p>
                    </div>
                    </div>
                </div>

                <!-- Camera Ready Final Paper -->
                <div class="col-lg-4 col-md-6">
                    <div class="stat-item">
                    <div class="stat-icon">
                        <i class="bi bi-upload"></i>
                    </div>
                    <div class="stat-content">
                        <h4>15 July 2026</h4>
                        <p class="mb-0">Camera Ready Final Paper</p>
                    </div>
                    </div>
                </div>

                <!-- Early Bird Registration -->
                <div class="col-lg-4 col-md-6">
                    <div class="stat-item">
                    <div class="stat-icon">
                        <i class="bi bi-credit-card-2-front-fill"></i>
                    </div>
                    <div class="stat-content">
                        <h4>22 July 2026</h4>
                        <p class="mb-0">Early Bird Registration</p>
                    </div>
                    </div>
                </div>

                </div>
            </div>
            </section>


            <div class="container section-title pt-4" data-aos="fade-up">
                <h2>Full Paper Submission</h2>
            </div>

            <div class="container">

                <div class="row gy-4">

                    <!-- Conference Brochure -->
                    <div class="col-lg-6 col-md-6 col-12" data-aos="zoom-in" data-aos-delay="100">
                        <div class="feature-box orange">
                            <i class="bi bi-journal-text"></i>
                            <h4>Conference Brochure</h4>
                            <p>
                                Download the official <a href="/assets/pdf/Symposium Brochure, IEES, 2026.pdf" target="_blank"> ISEE 2026 Conference Brochure</a> to
                                explore the event highlights, important dates, keynote speakers, technical sessions, and
                                participation guidelines. The brochure provides a complete overview of the symposium.
                            </p>
                        </div>
                    </div>

                    <!-- Paper Template -->
                    <div class="col-lg-6 col-md-6 col-12" data-aos="zoom-in" data-aos-delay="200">
                        <div class="feature-box blue">
                            <i class="bi bi-file-earmark-text"></i>
                            <h4>Paper Template</h4>
                            <p>
                                Full papers should be a minimum of 4 pages and a maximum of 6 pages. Authors must
                                strictly follow the official <a href="#" target="_blank">ISEE 2026 Full Paper Template
                                    (.docx)</a> for formatting, style, references, and structure to ensure uniformity
                                across all submissions.
                            </p>
                        </div>
                    </div>

                    <!-- Online Submission -->
                    <div class="col-lg-6 col-md-6 col-12" data-aos="zoom-in" data-aos-delay="300">
                        <div class="feature-box green">
                            <i class="bi bi-cloud-upload"></i>
                            <h4>Online Submission (CMT)</h4>
                            <p>
                                Submit your full paper through the <a href="#" target="_blank">CMT Submission
                                    Portal</a>. A Microsoft CMT account is required for submission. If you don’t have
                                one, please create an account before submitting. Only full papers will be accepted
                                through the portal (no separate abstract submission is required).
                            </p>
                        </div>
                    </div>

                    <!-- Contact Support -->
                    <div class="col-lg-6 col-md-6 col-12" data-aos="zoom-in" data-aos-delay="400">
                        <div class="feature-box red">
                            <i class="bi bi-envelope-fill"></i>
                            <h4>Contact for Support</h4>
                            <p>
                                If you encounter any issues during online submission or require clarification on
                                guidelines, please contact the conference secretary via email at <a
                                    href="mailto:isee2026@ruet.ac.bd">isee2026@ruet.ac.bd</a>. The organizing team will
                                be happy to assist you.
                            </p>
                        </div>
                    </div>

                </div>

            </div>

        </section>

    </main>

</Layout>