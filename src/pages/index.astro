---
import Layout from "../layouts/Layout.astro";
---

<Layout title="ISEE 2026" bodyClass="index-page" active="home">

    <main class="main">

    <!-- Hero Section -->
    <section id="hero" class="hero section">

      <div class="container" data-aos="fade-up" data-aos-delay="100">

        <div class="row align-items-center">
          <div class="col-lg-6">
            <div class="hero-content" data-aos="fade-up" data-aos-delay="200">

              <h1 class="mb-4">
                International Symposium on Energy and Environment <br>
                <span class="accent-text">ISEE 2026</span>
              </h1>

              <p class="mb-4 mb-md-5">
                <h4><strong>Venue:</strong> RUET Auditorium</h4>
                <h4><strong>Date:</strong> 20 August, 2026</h4><br>
              </p>

              <div class="hero-buttons">
                <a href="/Registration" class="btn btn-primary me-0 me-sm-2 mx-1">Register Now</a>
                <a href="https://youtu.be/C4XAo3nk_Bw" class="btn btn-link mt-2 mt-sm-0 glightbox">
                  <i class="bi bi-play-circle me-1"></i>
                  Play Video
                </a>
              </div>
            </div>
          </div>

          <div class="col-lg-6">
            <div class="hero-image" data-aos="zoom-out" data-aos-delay="300">
              <img src="/assets/img/4.webp" alt="Hero Image" class="img-fluid">
            </div>
          </div>

        </div>



        <div class="row stats-row gy-4 mt-5" data-aos="fade-up" data-aos-delay="500" style="font-size: 18px;">
          <marquee behavior="" direction="left"><b>Notice: </b>The abstract submission of ISEE 2026 is scheduled to
            15 April, 2026. <a href="/Registration">Click Here</a> to submit your paper</marquee>
        </div>

        <div class="row stats-row gy-4 mt-5" data-aos="fade-up" data-aos-delay="500">
          <div class="col-lg-4 col-md-6">
            <div class="stat-item">
              <div class="stat-icon">
                <i class="bi bi-journal-album"></i>
              </div>
              <div class="stat-content">
                <h4>15 April, 2026</h4>
                <p class="mb-0">Abstract Submission</p>
              </div>
            </div>
          </div>
          <div class="col-lg-4 col-md-6">
            <div class="stat-item">
              <div class="stat-icon">
                <i class="bi bi-clipboard2-check-fill"></i>
              </div>
              <div class="stat-content">
                <h4>11 June, 2026</h4>
                <p class="mb-0">Full Paper Submission</p>
              </div>
            </div>
          </div>
          <div class="col-lg-4 col-md-6">
            <div class="stat-item">
              <div class="stat-icon">
                <i class="bi bi-calendar2-fill"></i>
              </div>
              <div class="stat-content">
                <h4>20 August, 2026</h4>
                <p class="mb-0">Symposium Date</p>
              </div>
            </div>
          </div>
        </div>



      </div>

    </section><!-- /Hero Section -->


    <!-- Features Section -->
    <section id="features" class="features section">

      <!-- Section Title -->
      <div class="container section-title" data-aos="fade-up">
        <h2>Conference Topics</h2>
        <p>ISEE 2026 at RUET highlights cutting-edge research in energy and environmental fields, fostering sustainable
          technologies and solutions for global challenges.</p>
      </div><!-- End Section Title -->


      <div class="container">

        <div class="d-flex justify-content-center">

          <ul class="nav nav-tabs" data-aos="fade-up" data-aos-delay="100">

            <li class="nav-item">
              <a class="nav-link active show" data-bs-toggle="tab" data-bs-target="#features-tab-1">
                <h4>Energy</h4>
              </a>
            </li><!-- End tab nav item -->

            <li class="nav-item">
              <a class="nav-link" data-bs-toggle="tab" data-bs-target="#features-tab-2">
                <h4>Environment</h4>
              </a>
            </li><!-- End tab nav item -->

            <li class="nav-item">
              <a class="nav-link" data-bs-toggle="tab" data-bs-target="#features-tab-3">
                <h4>Sustainability</h4>
              </a>
            </li><!-- End tab nav item -->

          </ul>

        </div>

        <div class="tab-content" data-aos="fade-up" data-aos-delay="200">

          <!-- Tab 1 -->
          <div class="tab-pane fade active show" id="features-tab-1">
            <div class="row gy-4 align-items-center">
              <div class="col-lg-6 order-2 order-lg-1 mt-3 mt-lg-0 d-flex flex-column justify-content-center">
                <h3>Advanced Energy Systems</h3>
                <p class="fst-italic">
                  Explores innovative energy technologies, efficiency improvements, and next-gen solutions for cleaner
                  and smarter power systems.
                </p>
                <ul>
                  <li><i class="bi bi-check-circle-fill"></i> <span>Renewable Energy Technologies</span></li>
                  <li><i class="bi bi-check-circle-fill"></i> <span>Hydrogen and Fuel Cell Technologies</span></li>
                  <li><i class="bi bi-check-circle-fill"></i> <span>Nuclear Energy & Safety</span></li>
                  <li><i class="bi bi-check-circle-fill"></i> <span>Green & Advanced Energy Materials</span></li>
                  <li><i class="bi bi-check-circle-fill"></i> <span>Energy Systems Modeling & Digital
                      Transformation</span></li>
                  <li><i class="bi bi-check-circle-fill"></i> <span>Energy Efficiency, Conservation & Storage</span>
                  </li>
                </ul>


              </div>
              <div class="col-lg-6 order-1 order-lg-2 text-center">
                <img src="/assets/img/8.webp" alt="" class="img-fluid">
              </div>
            </div>
          </div><!-- End tab content item -->

          <!-- Tab 2 -->
          <div class="tab-pane fade" id="features-tab-2">
            <div class="row gy-4 align-items-center">
              <div class="col-lg-6 order-2 order-lg-1 mt-3 mt-lg-0 d-flex flex-column justify-content-center">
                <h3>Environmental Challenges & Solutions</h3>
                <p class="fst-italic">
                  Focuses on climate resilience, pollution control, and sustainable practices to protect ecosystems and
                  human health.
                </p>
                <ul>
                  <li><i class="bi bi-check-circle-fill"></i> <span>Climate Change Mitigation & Adaptation</span></li>
                  <li><i class="bi bi-check-circle-fill"></i> <span>Carbon Capture, Utilization & Storage (CCUS)</span>
                  </li>
                  <li><i class="bi bi-check-circle-fill"></i> <span>Pollution Control & Remediation</span></li>
                  <li><i class="bi bi-check-circle-fill"></i> <span>Circular Economy & Waste Management</span></li>
                  <li><i class="bi bi-check-circle-fill"></i> <span>Marine, Coastal & Agricultural Sustainability</span>
                  </li>
                  <li><i class="bi bi-check-circle-fill"></i> <span>Environmental Health & Risk Assessment</span></li>
                  <li><i class="bi bi-check-circle-fill"></i> <span>Life-Cycle Assessment & Impact Analysis</span></li>
                </ul>



              </div>
              <div class="col-lg-6 order-1 order-lg-2 text-center">
                <img src="/assets/img/7.webp" alt="" class="img-fluid">
              </div>
            </div>
          </div><!-- End tab content item -->

          <!-- Tab 3 -->
          <div class="tab-pane fade" id="features-tab-3">
            <div class="row gy-4 align-items-center">
              <div class="col-lg-6 order-2 order-lg-1 mt-3 mt-lg-0 d-flex flex-column justify-content-center">
                <h3>Sustainable Development & Infrastructure</h3>
                <p class="fst-italic">
                  Addresses urban growth, smart cities, and sustainable transport to build resilient and future-ready
                  infrastructure.
                </p>
                <ul>
                  <li><i class="bi bi-check-circle-fill"></i> <span>Sustainable Transportation & Fuels</span></li>
                  <li><i class="bi bi-check-circle-fill"></i> <span>Sustainable Building & Urban Infrastructure</span>
                  </li>
                  <li><i class="bi bi-check-circle-fill"></i> <span>Smart Cities & Climate-Resilient
                      Infrastructure</span></li>
                  <li><i class="bi bi-check-circle-fill"></i> <span>Environmental Policy, Governance & Economics</span>
                  </li>
                </ul>


              </div>
              <div class="col-lg-6 order-1 order-lg-2 text-center">
                <img src="/assets/img/6.webp" alt="" class="img-fluid">
              </div>
            </div>
          </div><!-- End tab content item -->

        </div>

      </div>

    </section><!-- /Features Section -->





    <!-- Call To Action Section -->
    <section id="call-to-action" class="call-to-action section">

      <div class="container" data-aos="fade-up" data-aos-delay="100">

        <div class="row content justify-content-center align-items-center position-relative">
          <div class="col-lg-8 mx-auto text-center">
            <h2 class="display-4 mb-4"> Call for Paper</h2>
            <p class="mb-4">The manuscript will undergo peer review prior to final acceptance. Guidelines for the
              preparation of both the initial review submission and the final camera-ready version will be available on
              the conference website. Manuscripts that do not adhere to the specified guidelines will be deemed
              ineligible for the review process.</p>
            <a href="/Registration" class="btn btn-cta">Submit The Abstract</a>
          </div>

          <!-- Abstract Background Elements -->
          <div class="shape shape-1">
            <svg viewBox="0 0 200 200" xmlns="http://www.w3.org/2000/svg">
              <path
                d="M47.1,-57.1C59.9,-45.6,68.5,-28.9,71.4,-10.9C74.2,7.1,71.3,26.3,61.5,41.1C51.7,55.9,35,66.2,16.9,69.2C-1.3,72.2,-21,67.8,-36.9,57.9C-52.8,48,-64.9,32.6,-69.1,15.1C-73.3,-2.4,-69.5,-22,-59.4,-37.1C-49.3,-52.2,-32.8,-62.9,-15.7,-64.9C1.5,-67,34.3,-68.5,47.1,-57.1Z"
                transform="translate(100 100)"></path>
            </svg>
          </div>

          <div class="shape shape-2">
            <svg viewBox="0 0 200 200" xmlns="http://www.w3.org/2000/svg">
              <path
                d="M41.3,-49.1C54.4,-39.3,66.6,-27.2,71.1,-12.1C75.6,3,72.4,20.9,63.3,34.4C54.2,47.9,39.2,56.9,23.2,62.3C7.1,67.7,-10,69.4,-24.8,64.1C-39.7,58.8,-52.3,46.5,-60.1,31.5C-67.9,16.4,-70.9,-1.4,-66.3,-16.6C-61.8,-31.8,-49.7,-44.3,-36.3,-54C-22.9,-63.7,-8.2,-70.6,3.6,-75.1C15.4,-79.6,28.2,-58.9,41.3,-49.1Z"
                transform="translate(100 100)"></path>
            </svg>
          </div>

          <!-- Dot Pattern Groups -->
          <div class="dots dots-1">
            <svg viewBox="0 0 100 100" xmlns="http://www.w3.org/2000/svg">
              <pattern id="dot-pattern" x="0" y="0" width="20" height="20" patternUnits="userSpaceOnUse">
                <circle cx="2" cy="2" r="2" fill="currentColor"></circle>
              </pattern>
              <rect width="100" height="100" fill="url(#dot-pattern)"></rect>
            </svg>
          </div>

          <div class="dots dots-2">
            <svg viewBox="0 0 100 100" xmlns="http://www.w3.org/2000/svg">
              <pattern id="dot-pattern-2" x="0" y="0" width="20" height="20" patternUnits="userSpaceOnUse">
                <circle cx="2" cy="2" r="2" fill="currentColor"></circle>
              </pattern>
              <rect width="100" height="100" fill="url(#dot-pattern-2)"></rect>
            </svg>
          </div>

          <div class="shape shape-3">
            <svg viewBox="0 0 200 200" xmlns="http://www.w3.org/2000/svg">
              <path
                d="M43.3,-57.1C57.4,-46.5,71.1,-32.6,75.3,-16.2C79.5,0.2,74.2,19.1,65.1,35.3C56,51.5,43.1,65,27.4,71.7C11.7,78.4,-6.8,78.3,-23.9,72.4C-41,66.5,-56.7,54.8,-65.4,39.2C-74.1,23.6,-75.8,4,-71.7,-13.2C-67.6,-30.4,-57.7,-45.2,-44.3,-56.1C-30.9,-67,-15.5,-74,0.7,-74.9C16.8,-75.8,33.7,-70.7,43.3,-57.1Z"
                transform="translate(100 100)"></path>
            </svg>
          </div>
        </div>

      </div>

    </section><!-- /Call To Action Section -->

    <!-- Testimonials Section -->
    <section id="testimonials" class="testimonials section light-background">

      <!-- Section Title -->
      <div class="container section-title" data-aos="fade-up">
        <h2>Keynote Speakers</h2>
        <p style="text-align: justify;">The keynote sessions at ISEE 2026 will feature distinguished experts and thought
          leaders from academia and
          industry. They will share insights on emerging trends, cutting-edge research, and future challenges in
          Mechanical, Industrial, and Sustainable Engineering, inspiring innovation and collaboration among
          participants.</p>
      </div><!-- End Section Title -->

      <div class="container">

        <div class="row g-5">


