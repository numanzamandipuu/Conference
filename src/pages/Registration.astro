---
import Layout from "../layouts/Layout.astro";
---

<Layout title="Registration | ISEE 2026" bodyClass="inner-page" active="registration">

      <main class="main">

        <div class="page-title light-background">
            <div class="container">
                <h1>Registration Procedure</h1>
                <nav class="breadcrumbs">
                    <ol>
                        <li><a href="index.html">Home</a></li>
                        <li class="current">Registration</li>
                    </ol>
                </nav>
            </div>
        </div>

        <section id="features-cards" class="features-cards section hero-date">
            <div class="container section-title pb-0" data-aos="fade-up">
                <h2>Registration Fees</h2>
            </div>

            <div class="container" data-aos="fade-up">
                <table class="table table-striped">
                    <thead>
                        <tr>
                            <th scope="col">Category</th>
                            <th scope="col">Amount</th>
                        </tr>
                    </thead>
                    <tbody>
                        <tr>
                            <td>International Delegates</td>
                            <td>USD 250</td>
                        </tr>
                        <tr>
                            <td>SAARC Participants</td>
                            <td>USD 150</td>
                        </tr>
                        <tr>
                            <td>Students (Foreign)</td>
                            <td>USD 150</td>
                        </tr>
                        <tr>
                            <td>Local Authors</td>
                            <td>BDT 6000</td>
                        </tr>
                        <tr>
                            <td>Students (Local)</td>
                            <td>BDT 3500</td>
                        </tr>
                        <tr>
                            <td>Industry professionals (Non-Authors)</td>
                            <td>BDT 8000</td>
                        </tr>
                        <tr>
                            <td>Accompanying Person</td>
                            <td>BDT 2000</td>
                        </tr>
                    </tbody>
                </table>
                
                <div class="mt-3">
                    <p><strong>Additional paper submission:</strong> +20% fee each</p>
                    <p><strong>After early bird (22 July 2026):</strong> Registration +20% extra</p>
                </div>
            </div>
        </section>

        <section id="contact" class="contact section light-background">

        <!-- Section Title -->
        <div class="container section-title" data-aos="fade-up">
            <h2>Registration Form</h2>

        </div><!-- End Section Title -->

        <div class="container" data-aos="fade-up" data-aos-delay="100">

            <div class="row g-4 g-lg-5">
            <div class="col">
                <div class="contact-form" data-aos="fade-up" data-aos-delay="300">

                <form action="forms/contact.php" method="post" class="php-email-form" data-aos="fade-up" data-aos-delay="200">
                    <div class="row gy-4">

                    <div class="col-md-6">
                        <input type="text" name="full_name" class="form-control" placeholder="Full Name" required>
                    </div>

                    <div class="col-md-6 ">
                        <input type="email" name="email" class="form-control" placeholder="Email Address" required>
                    </div>

                    <div class="col-md-6">
                        <input type="text" name="institution" class="form-control" placeholder="Institution/Organization Name" required>
                    </div>

                    <div class="col-md-6">
                        <input type="tel" name="phone" class="form-control" placeholder="Phone Number (WhatsApp preferred)" required>
                    </div>

                    <div class="col-md-6">
                        <input type="text" name="designation" class="form-control" placeholder="Designation" required>
                    </div>

                    <div class="col-12">
                        <label class="form-label">Upload Your Payment Slip *</label>
                        <input 
                        type="file" 
                        name="voucher" 
                        class="form-control" 
                        accept=".pdf,.jpg,.jpeg,.png"
                        required
                        >
                        <small class="text-muted">Max file size: 10MB</small>
                    </div>

                    <div class="col-12 text-center">
                        <button type="submit" class="btn">
                        Submit Registration
                        </button>
                    </div>

                    </div>
                </form>

                </div>
            </div>

            </div>

        </div>

        </section><!-- /Contact Section -->

        <section id="features-cards" class="features-card section" data-aos="fade-up">


            <div class="container">
                <div class="container section-title pb-0" data-aos="fade-up">
                    <h2>Payment System</h2>
                </div>
                <p style="text-align: justify;">All conference participants must be registered. Pre-registered
                    participants will be assured of being given the entire conference material package upon their
                    arrival in the conference venue. Advance registrations are preferable because of better planning of
                    the technical sessions and social events of the conference. Onsite registration is strongly
                    discouraged. Registration fee is not refundable upon registration has been completed.</p>
            </div>

            <div class="container my-5" data-aos="fade-up" data-aos-delay="400">
                <div class="row justify-content-center">
                    <div class="col-12 col-sm-6 col-md-4 text-center">
                        <button class="btn custom-btn">
                            Click Here to Pay
                        </button>
                    </div>
                </div>
            </div>



        </section>

    </main>

</Layout>