---
const { active = "" } = Astro.props;
---

<header id="header" class="header d-flex align-items-center fixed-top">
  <div class="header-container container-fluid container-xl position-relative d-flex align-items-center justify-content-between">

    <!-- Logo -->
    <a href="/" class="logo d-flex align-items-center me-auto me-xl-0">
      <img src="/assets/img/logo.png" alt="ISEE Logo">
      <h1 class="sitename">ISEE</h1>
    </a>

    <!-- Navigation -->
    <nav id="navmenu" class="navmenu">
      <ul>
        <li>
          <a href="/" class={active === "home" ? "active" : ""}>
            Home
          </a>
        </li>

        <li>
          <a href="/Submission" class={active === "submission" ? "active" : ""}>
            Submission
          </a>
        </li>

        <li>
          <a href="/Registration" class={active === "registration" ? "active" : ""}>
            Registration
          </a>
        </li>

        <li>
          <a href="/Best_Paper" class={active === "best-paper" ? "active" : ""}>
            Best Paper Award
          </a>
        </li>

        <li>
          <a href="/Keynote" class={active === "keynote" ? "active" : ""}>
            Keynote Speakers
          </a>
        </li>

        <li>
          <a href="/Committee" class={active === "committee" ? "active" : ""}>
            Committee
          </a>
        </li>

        <li>
          <a href="/Contact" class={active === "contact" ? "active" : ""}>
            Contact
          </a>
        </li>
      </ul>

      <!-- Mobile Toggle -->
      <i class="mobile-nav-toggle d-xl-none bi bi-list"></i>
    </nav>

    <!-- CTA Button -->
    <a class="btn-getstarted" href="https://cmt3.research.microsoft.com/ISEE2026/Submission/Index" target="_blank">
      Submit Abstract
    </a>

  </div>
</header>